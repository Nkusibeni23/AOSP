# Copy to .env and fill in. .env is gitignored.

# --- Server ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# --- Auth ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-64-byte-random-hex
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=2592000

# --- Email domain (for enrollment) ---
ALLOWED_EMAIL_DOMAIN=rmsoft.rw

# --- Database (matches docker-compose.yml) ---
DATABASE_URL=postgresql://rmsoft:rmsoft_dev@localhost:5433/rmsoft?schema=public

# --- MQTT broker (matches docker-compose.yml) ---
MQTT_URL=mqtt://localhost:1883
MQTT_USERNAME=server
MQTT_PASSWORD=server_dev_password

# --- Redis (for command queue) ---
REDIS_URL=redis://localhost:6379

# --- Public URLs phones use (set when deploying) ---
PUBLIC_API_URL=https://dashboard.rmsoft.local
PUBLIC_MQTT_URL=mqtts://mqtt.rmsoft.local:8883
